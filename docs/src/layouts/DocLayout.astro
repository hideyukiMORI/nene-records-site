---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  section?: string
}

const {
  title = 'NeNe Records Developer Docs',
  description = 'API reference, MCP tools, and developer guides for NeNe Records.',
  section,
} = Astro.props

const pageTitle = section ? `${section} — NeNe Records Dev` : title

const nav = [
  { label: 'Getting Started', href: '/getting-started' },
  { label: 'API Reference', href: '/api' },
  { label: 'MCP Tools', href: '/mcp' },
  { label: 'Problem Details', href: '/problems' },
  { label: 'OpenAPI Spec', href: '/openapi' },
  { label: 'Changelog', href: 'https://github.com/hideyukiMORI/nene-records/blob/main/CHANGELOG.md', external: true },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-gray-950 text-gray-100 antialiased">

    <!-- Top bar -->
    <header class="sticky top-0 z-50 border-b border-white/10 bg-gray-950/90 backdrop-blur-md">
      <div class="flex h-14 items-center gap-6 px-6">
        <a href="/" class="flex items-center gap-2 font-bold text-white">
          <span class="text-nene-400">⬡</span>
          <span class="text-sm">NeNe Records</span>
          <span class="rounded bg-nene-950 px-1.5 py-0.5 text-xs text-nene-400 border border-nene-500/30">dev</span>
        </a>

        <nav class="hidden items-center gap-4 text-sm text-gray-400 md:flex">
          {nav.map((item) => (
            <a
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener noreferrer' : undefined}
              class="transition hover:text-white"
            >
              {item.label}{item.external ? ' ↗' : ''}
            </a>
          ))}
        </nav>

        <div class="ml-auto flex items-center gap-3">
          <a
            href="https://nene-records.com"
            class="text-sm text-gray-400 transition hover:text-white"
          >
            ← Product site
          </a>
          <a
            href="https://github.com/hideyukiMORI/nene-records"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 rounded border border-white/20 px-3 py-1 text-sm transition hover:border-white/40"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </header>

    <!-- Layout -->
    <div class="mx-auto flex max-w-7xl">
      <!-- Sidebar -->
      <aside class="hidden w-60 shrink-0 border-r border-white/10 md:block">
        <nav class="sticky top-14 max-h-[calc(100vh-3.5rem)] overflow-y-auto p-4">
          <div class="space-y-1">
            {nav.map((item) => (
              <a
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
                class={`flex items-center gap-2 rounded-md px-3 py-2 text-sm transition ${
                  Astro.url.pathname.startsWith(item.href) && !item.external
                    ? 'bg-nene-950 text-nene-300 font-medium'
                    : 'text-gray-400 hover:bg-white/5 hover:text-white'
                }`}
              >
                {item.label}
                {item.external && <span class="text-xs opacity-50">↗</span>}
              </a>
            ))}
          </div>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="min-w-0 flex-1 px-8 py-10">
        <article class="prose max-w-3xl">
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>
