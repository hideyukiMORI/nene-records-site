---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = 'NeNe Records — API-first Flexible Entity Platform',
  description = '型安全・MCP対応の軽量ヘッドレス CMS プラットフォーム。WordPress より軽く、より型安全に。',
  ogImage = '/og.png',
} = Astro.props
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://nene-records.com" />
    <meta property="og:image" content={`https://nene-records.com${ogImage}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://nene-records.com${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class="bg-gray-950 text-gray-100 antialiased">
    <slot />
  </body>
</html>
